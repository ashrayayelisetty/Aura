# AURA-VIP Configuration Template
# Copy this file to .env and update with your values

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/aura_vip
# For development, you can use SQLite:
# DATABASE_URL=sqlite:///./aura_vip.db

# Face Recognition Configuration
FACE_CONFIDENCE_THRESHOLD=0.85
FACE_RECOGNITION_MODEL=VGG-Face
CAMERA_RESOLUTION_WIDTH=640
CAMERA_RESOLUTION_HEIGHT=480
FRAME_PROCESSING_RATE=2

# Lounge Configuration
LOUNGE_MAX_CAPACITY=50
LOUNGE_DEFAULT_DURATION_MINUTES=90

# Flight Monitoring Configuration
FLIGHT_CHECK_INTERVAL_SECONDS=60
BOARDING_ALERT_MINUTES=15
BOARDING_TIME_BEFORE_DEPARTURE_MINUTES=30

# Buggy Configuration
BUGGY_MIN_BATTERY_LEVEL=20
BUGGY_BATTERY_DEPLETION_PER_TRIP=5
BUGGY_TRIP_ARRIVAL_TO_LOUNGE_MINUTES=5
BUGGY_TRIP_LOUNGE_TO_GATE_MINUTES=7

# Demo Configuration
DEMO_STATE_TRANSITION_DELAY_SECONDS=30
DEMO_FLIGHT_DELAY_MINUTES=30

# WebSocket Configuration
WEBSOCKET_UPDATE_LATENCY_MS=500

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
